datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

generator client {
   provider = "prisma-client-js"
}

enum Role {
   STUDENT
   ADMIN
}

model User {
   id       String @id @default(uuid()) @db.Uuid
   email    String @unique
   password String
   role     Role

   refreshTokenHash String? @map("refresh_token_hash")
   tokenVersion     Int     @default(0) @map("token_version")

   resetPasswordTokenHash      String?   @map("reset_password_token_hash")
   resetPasswordTokenExpiresAt DateTime? @map("reset_password_token_expires_at")

   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @updatedAt @map("updated_at")

   studentProfile StudentProfile?
   adminProfile   AdminProfile?

   groups Group[] @relation("GroupUsers")

   @@map("users")
}

model StudentProfile {
   userId      String  @id @map("user_id") @db.Uuid
   user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
   firstName   String  @map("first_name")
   lastName    String  @map("last_name")
   email       String
   phoneNumber String? @map("phone_number")
   country     String? @map("country")
   city        String? @map("city")
   comment     String? @map("comment")

   groups Group[] @relation("GroupStudentProfiles")

   @@index([email])
   @@index([firstName, lastName])
   @@map("student_profiles")
}

model AdminProfile {
   userId String @id @map("user_id") @db.Uuid

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   firstName String? @map("first_name")
   lastName  String? @map("last_name")

   email String

   @@index([email])
   @@map("admin_profiles")
}

model Lesson {
   id        String   @id @default(uuid()) @db.Uuid
   title     String   @db.VarChar(150)
   comment   String?  @db.VarChar(500)
   payload   Json?
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @updatedAt @map("updated_at")

   groups Group[] @relation("GroupLessons")

   @@index([title])
   @@map("lessons")
}

model Group {
   id         String   @id @default(uuid()) @db.Uuid
   groupName  String   @map("group_name") @db.VarChar(150)
   courseName String   @map("course_name") @db.VarChar(150)
   comment    String?  @map("comment") @db.VarChar(500)
   startDate  DateTime @map("start_date")
   createdAt  DateTime @default(now()) @map("created_at")
   updatedAt  DateTime @updatedAt @map("updated_at")

   users           User[]           @relation("GroupUsers")
   studentProfiles StudentProfile[] @relation("GroupStudentProfiles")
   lessons         Lesson[]         @relation("GroupLessons")

   @@index([groupName])
   @@index([courseName])
   @@index([startDate])
   @@map("groups")
}
