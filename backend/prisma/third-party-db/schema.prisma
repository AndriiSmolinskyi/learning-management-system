generator client {
   provider      = "prisma-client-js"
   binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
   output        = "../../node_modules/@third-party-prisma/client"
}

datasource db {
   provider = "postgresql"
   url      = env("THIRD_PARTY_DATABASE_URL")
}

// - Defines a list of supported fiat currencies.
enum CurrencyDataList {
   AED
   AUD
   BRL
   CAD
   CHF
   EUR
   GBP
   HKD
   ILS
   JPY
   MXN
   NOK
   RUB
   TRY
   USD
   ZAR
   DKK
   SEK
   KRW
   CNY
   KZT
}

// - Defines a list of supported precious metals.
enum MetalDataList {
   XAU
   XAG
   XPT
   XPD
}

// - Defines a list of supported cryptocurrencies.
enum CryptoList {
   BTC
   ETH
}

// - Classifies ISIN codes into asset categories:
// Bond: Represents bond assets.
// Equity: Represents equity assets.
// ETF: Represents exchange-traded funds.
enum IsinType {
   Bond
   Equity
   ETF
}

// - Stores CBonds API datasets in JSON format for financial analytics.
model CBonds {
   id                    String   @id @unique @default(uuid()) @db.Uuid
   tradingsNew           Json     @map("tradings_new")
   emissions             Json
   tradingsStocksFullNew Json     @map("tradings_stocks_full_new")
   stocksTradingGrounds  Json     @map("stocks_trading_grounds")
   stocksFull            Json     @map("stocks_full")
   emitents              Json
   etfDividends          Json     @map("etf_dividends")
   etfFunds              Json     @map("etf_funds")
   etfQuotes             Json     @map("etf_quotes")
   etfTradingGrounds     Json     @map("etf_trading_grounds")
   createdAt             DateTime @default(now()) @map("created_at")
   updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

   @@index([createdAt])
}

// - Stores exchange rates for fiat currencies.
model CurrencyData {
   id              String                @id @default(uuid()) @db.Uuid
   currency        CurrencyDataList      @unique
   currencyId      String                @unique @map("currency_id")
   rate            Float
   typeId          String                @unique @map("type_id")
   createdAt       DateTime              @default(now()) @map("created_at")
   updatedAt       DateTime              @default(now()) @updatedAt @map("updated_at")
   isins           Isins[]
   currencyHistory CurrencyHistoryData[]
   Equity          Equity[]
   Etf             Etf[]
}

// - Stores history exchange rates for fiat currencies.
model CurrencyHistoryData {
   id         String       @id @default(uuid()) @db.Uuid
   rate       Float
   date       DateTime
   currencyId String       @map("currency_id") @db.Uuid
   currency   CurrencyData @relation(fields: [currencyId], references: [id])
}

// - Stores data for supported cryptocurrencies.
model CryptoData {
   id            String              @id @default(uuid()) @db.Uuid
   name          String              @unique
   token         CryptoList          @unique
   rate          Float
   createdAt     DateTime            @default(now()) @map("created_at")
   updatedAt     DateTime            @default(now()) @updatedAt @map("updated_at")
   cryptoHistory CryptoHistoryData[]
}

// - Stores history exchange rates for cryptocurrencies.
model CryptoHistoryData {
   id      String     @id @default(uuid()) @db.Uuid
   rate    Float
   date    DateTime
	crypto  CryptoList
   tokenId String     @map("token_id") @db.Uuid
   token   CryptoData @relation(fields: [tokenId], references: [id])
}

// - Stores pricing data for precious metals.
model MetalData {
   id              String             @id @default(uuid()) @db.Uuid
   currency        MetalDataList      @unique
   rate            Float
   createdAt       DateTime           @default(now()) @map("created_at")
   updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at")
   currencyHistory MetalHistoryData[]
}

// - Stores history exchange rates for metal currencies.
model MetalHistoryData {
   id         String    @id @default(uuid()) @db.Uuid
   rate       Float
   date       DateTime
   currencyId String    @map("currency_id") @db.Uuid
   currency   MetalData @relation(fields: [currencyId], references: [id])
}

// - Registry of ISIN codes with classification and activation status.
model Isins {
   id          Int          @id @default(autoincrement())
   isin        String       @unique
   isActivated Boolean      @default(false) @map("is_activated")
   typeId      String       @map("type_id")
   type        IsinType
   createdAt   DateTime     @default(now()) @map("created_at")
   updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at")
   currencyId  String       @map("currency_id")
   currency    CurrencyData @relation(fields: [currencyId], references: [currencyId])

   bond   Bond[]
   equity Equity[]
   etf    Etf[]
}

// - Stores CBonds data for bond isins.
model Bond {
   id                 Int       @id @default(autoincrement())
   isin               String    @unique()
   security           String
   marketPrice        Float     @map("market_price")
   dirtyPriceCurrency Float?    @map("dirty_price_currency")
   yield              Float?
   sellingQuote       Float     @map("selling_quote")
   ytcOffer           Float?    @map("ytc_offer")
   gSpread            Float?    @map("g_spread")
   accrued            Float?
   tradeDate          DateTime  @map("trade_date")
   issuer             String?
   nominalPrice       String?   @map("nominal_price")
   maturityDate       DateTime? @map("maturity_date")
   country            String
   sector             String?
   coupon             String?
   nextCouponDate     DateTime? @map("next_coupon_date")
   offertDateCall     DateTime? @map("offert_date_call")

   isinId  Int
   isinRef Isins @relation(fields: [isinId], references: [id])

   createdAt   DateTime      @default(now()) @map("created_at")
   updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")
   bondHistory BondHistory[]

   @@index([isin])
}

// - Stores historical data for bonds.
model BondHistory {
   id     Int  @id @default(autoincrement())
   bondId Int
   bond   Bond @relation(fields: [bondId], references: [id])

   isin               String
   security           String
   marketPrice        Float     @map("market_price")
   dirtyPriceCurrency Float?    @map("dirty_price_currency")
   yield              Float?
   sellingQuote       Float     @map("selling_quote")
   ytcOffer           Float?    @map("ytc_offer")
   gSpread            Float?    @map("g_spread")
   accrued            Float?
   tradeDate          DateTime  @map("trade_date")
   issuer             String?
   nominalPrice       String?   @map("nominal_price")
   maturityDate       DateTime? @map("maturity_date")
   country            String
   sector             String?
   coupon             String?
   nextCouponDate     DateTime? @map("next_coupon_date")
   offertDateCall     DateTime? @map("offert_date_call")

   createdAt DateTime

   @@index([createdAt])
}

// - Stores equities data.
model Equity {
   id                Int     @id @default(autoincrement())
   isin              String
   ticker            String
   tradingGroundId   Int     @map("trading_ground_id")
   lastPrice         Float   @map("last_price")
   emitentName       String  @map("emitent_name")
   emitentBranchId   String  @map("emitent_branch_id")
   tradingGroundName String  @map("trading_ground_name")
   equityCurrencyId  String  @map("equity_currency_id")
   currencyName      String  @map("currency_name")
   stockEmitentId    String  @map("stock_emitent_id")
   stockEmitentName  String  @map("stock_emitent_name")
   stockCountryName  String  @map("stock_country_name")
   branchName        String? @map("branch_name")

   isinId     Int
   isinRef    Isins        @relation(fields: [isinId], references: [id])
   currencyId String       @map("currency_id")
   currency   CurrencyData @relation(fields: [currencyId], references: [currencyId])

   createdAt     DateTime        @default(now()) @map("created_at")
   updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
   equityHistory EquityHistory[]

   @@unique([isin, currencyId])
   @@index([isin])
   @@index([currencyId])
}

// - Stores historical data for equities.
model EquityHistory {
   id       Int    @id @default(autoincrement())
   equityId Int
   equity   Equity @relation(fields: [equityId], references: [id])

   isin              String
   ticker            String
   tradingGroundId   Int     @map("trading_ground_id")
   lastPrice         Float   @map("last_price")
   emitentName       String  @map("emitent_name")
   emitentBranchId   String  @map("emitent_branch_id")
   tradingGroundName String  @map("trading_ground_name")
   equityCurrencyId  String  @map("equity_currency_id")
   currencyName      String  @map("currency_name")
   stockEmitentId    String  @map("stock_emitent_id")
   stockEmitentName  String  @map("stock_emitent_name")
   stockCountryName  String  @map("stock_country_name")
   branchName        String? @map("branch_name")

   createdAt DateTime

   @@index([createdAt])
}

// - Stores ETF data.
model Etf {
   id                      Int    @id @default(autoincrement())
   isin                    String
   ticker                  String
   close                   Float
   distributionAmount      Float  @map("distribution_amount")
   currencyName            String @map("currency_name")
   fundsName               String @map("funds_name")
   tradingGroundName       String @map("trading_ground_name")
   geographyInvestmentName String @map("geography_investment_name")
   sectorName              String @map("sector_name")
   tradingGroundId         Int    @map("trading_ground_id")
   etfCurrencyId           String @map("equity_currency_id")

   isinId     Int
   isinRef    Isins        @relation(fields: [isinId], references: [id])
   currencyId String       @map("currency_id")
   currency   CurrencyData @relation(fields: [currencyId], references: [currencyId])

   createdAt  DateTime     @default(now()) @map("created_at")
   updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at")
   etfHistory EtfHistory[]

   @@unique([isin, currencyId])
   @@index([isin])
   @@index([currencyId])
}

// - Stores historical data for ETFs.
model EtfHistory {
   id    Int @id @default(autoincrement())
   etfId Int
   etf   Etf @relation(fields: [etfId], references: [id])

   isin                    String
   ticker                  String
   close                   Float
   distributionAmount      Float  @map("distribution_amount")
   currencyName            String @map("currency_name")
   fundsName               String @map("funds_name")
   tradingGroundName       String @map("trading_ground_name")
   geographyInvestmentName String @map("geography_investment_name")
   sectorName              String @map("sector_name")
   tradingGroundId         Int    @map("trading_ground_id")
   etfCurrencyId           String @map("equity_currency_id")

   createdAt DateTime

   @@index([createdAt])
}

// - Stores equity emitents.
model Emitent {
   id            String   @id @unique
   branchNameEng String   @map("branch_name_eng")
   createdAt     DateTime @default(now()) @map("created_at")

   @@index([id])
}
