generator client {
   provider      = "prisma-client-js"
   binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

// Represents the status of a document: pending approval, approved, or declined.
enum DocumentStatus {
   PENDING
   APPROVED
   DECLINED
}

// Defines the type of client request: Sell, Buy, Deposit, or Other.
enum RequestType {
   Sell
   Buy
   Deposit
   Other
}

// Describes the type of order being placed: Buy or Sell.
enum OrderType {
   Buy
   Sell
}

// Enumerates supported currency codes used across the platform for financial operations.
enum CurrencyDataList {
   AED
   AUD
   BRL
   CAD
   CHF
   EUR
   GBP
   HKD
   ILS
   JPY
   MXN
   NOK
   RUB
   TRY
   USD
   ZAR
   DKK
   SEK
   KRW
   CNY
   KZT
}

// - Defines a list of supported precious metals.
enum MetalDataList {
   XAU
   XAG
   XPT
   XPD
}

// - Defines a list of supported cryptocurrencies.
enum CryptoList {
   BTC
   ETH
}

// - Defines a type of crypto.
enum CryptoType {
   DirectHold
   ETF
}

// - Classifies ISIN codes into asset categories:
// Bond: Represents bond assets.
// Equity: Represents equity assets.
// ETF: Represents exchange-traded funds.
enum IsinType {
   Bond
   Equity
   ETF
}

// - Represents the types of entities that can be deleted/edited/transfered and logged.
enum LogInstanceType {
   Client
   Portfolio
   Budget
   Asset
   AssetVersion
   Transaction
}

// - Represents the types of actions that can be logged.
enum LogActionType {
   Edit
   Transfer
}

// - Represents the types of equities.
enum EquityType {
   Equity
   ETF
}

// Represents an end-user (typically a person or institution) that owns and manages financial entities within the platform.
// Acts as the main anchor point for all related data: portfolios, transactions, requests, assets, and budget plans.
// Linked to one User for authentication, and holds contact details via Email and Phone.
model Client {
   id                           String                        @id @default(uuid()) @db.Uuid
   firstName                    String                        @map("first_name")
   lastName                     String                        @map("last_name")
   residence                    String
   country                      String
   region                       String
   city                         String
   streetAddress                String                        @map("street_address")
   buildingNumber               String                        @map("building_number")
   postalCode                   String                        @map("postal_code")
   isActivated                  Boolean                       @default(true) @map("is_activated")
   comment                      String?                       @db.Text
   createdAt                    DateTime                      @default(now()) @map("created_at")
   updatedAt                    DateTime                      @default(now()) @updatedAt @map("updated_at")
   totals                       Decimal                       @default(0) @db.Decimal(65, 2)
   user                         User?                         @relation("ClientToUser")
   emails                       Email[]
   contacts                     Phone[]
   portfolios                   Portfolio[]
   portfolioDrafts              PortfolioDraft[]
   banks                        Bank[]
   assets                       Asset[]
   requests                     Request[]
   requestDrafts                RequestDraft[]
   transactions                 Transaction[]
   transactionDrafts            TransactionDraft[]
   reports                      Report[]
   reportDrafts                 ReportDraft[]
   documents                    Document[]
   expenseCategoryList          ExpenseCategoryList[]
   budgetPlan                   BudgetPlan?
   budgetPlanDraft              BudgetPlanDraft?
   assetBondGroup               AssetBondGroup[]
   assetEquityGroup             AssetEquityGroup[]
   assetDeposit                 AssetDeposit[]
   assetCryptoGroup             AssetCryptoGroup[]
   assetMetalGroup              AssetMetalGroup[]
   assetLoan                    AssetLoan[]
   assetOption                  AssetOption[]
   assetRealEstate              AssetRealEstate[]
   assetOtherInvestment         AssetOtherInvestment[]
   assetPrivateEquity           AssetPrivateEquity[]
   assetCash                    AssetCash[]
   assetLoanVersions            AssetLoanVersion[]
   assetDepositVersions         AssetDepositVersion[]
   assetOptionVersions          AssetOptionVersion[]
   assetBondVersions            AssetBondVersion[]
   assetOtherInvestmentVersions AssetOtherInvestmentVersion[]
   assetPrivateEquityVersions   AssetPrivateEquityVersion[]
   assetRealEstateVersions      AssetRealEstateVersion[]
   assetEquityVersions          AssetEquityVersion[]

   @@index([isActivated])
}

// A temporary version of a Client used during onboarding or while editing client information.
// Allows safe drafting before promoting to a full Client record.
// Stores basic identity, address, and preliminary documents, emails, and phones.
model ClientDraft {
   id             String     @id @default(uuid()) @db.Uuid
   firstName      String?    @map("first_name")
   lastName       String?    @map("last_name")
   residence      String?
   country        String?
   region         String?
   city           String?
   streetAddress  String?    @map("street_address")
   buildingNumber String?    @map("building_number")
   postalCode     String?    @map("postal_code")
   emails         String[]   @default([])
   contacts       String[]   @default([])
   createdAt      DateTime   @default(now()) @map("created_at")
   updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at")
   documents      Document[]
}

// Represents login credentials and system-level user data.
// Each User is tied to a Client and an Email.
// Controls secure access and tracks user identity in the system.
model User {
   id        String   @id @default(uuid()) @db.Uuid
   clientId  String   @unique @map("client_id") @db.Uuid
   emailId   String   @unique @map("email_id") @db.Uuid
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
   client    Client   @relation("ClientToUser", fields: [clientId], references: [id], onDelete: Cascade)
   email     Email    @relation("EmailToUser", fields: [emailId], references: [id], onDelete: Cascade)
}

// Stores verified and unverified email addresses for a client or user.
// May include authentication credentials (password), a confirmation token, and status flag.
model Email {
   id              String   @id @default(uuid()) @db.Uuid
   clientId        String   @map("client_id") @db.Uuid
   email           String   @unique
   isConfirmed     Boolean  @default(false) @map("is_confirmed")
   password        String?  @db.VarChar(255)
   token           String?  @unique
   twoFactorSecret String?  @map("two_factor_secret") @db.VarChar(255)
   createdAt       DateTime @default(now()) @map("created_at")
   updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
   user            User?    @relation("EmailToUser")
   client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

   @@index([email])
   @@index([clientId])
}

// Represents a phone number associated with a client.
// Used for contact, verification, or client profile completion.
model Phone {
   id        String   @id @default(uuid()) @db.Uuid
   clientId  String   @map("client_id") @db.Uuid
   number    String   @unique
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
   client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

   @@index([number])
   @@index([clientId])
}

// Generic uploaded document entity that may be linked to any primary entity such as Client, Portfolio, Asset, Request, or Report.
// Includes file metadata like type, size, format, and storage reference.
// Supports versioning and document lifecycle via DocumentStatus.
model Document {
   id                     String                @id @default(uuid()) @db.Uuid
   clientId               String?               @map("client_id") @db.Uuid
   clientDraftId          String?               @map("client_draft_id") @db.Uuid
   portfolioId            String?               @map("portfolio_id") @db.Uuid
   portfolioDraftId       String?               @map("portfolio_draft_id") @db.Uuid
   entityId               String?               @map("entity_id") @db.Uuid
   assetId                String?               @map("asset_id") @db.Uuid
   requestId              Int?                  @map("request_id")
   requestDraftId         Int?                  @map("request_draft_id")
   transactionId          Int?                  @map("transaction_id")
   transactionDraftId     Int?                  @map("transaction_draft_id")
   reportId               Int?                  @map("report_id")
   reportDraftId          Int?                  @map("report_draft_id")
   name                   String
   type                   String
   status                 DocumentStatus
   format                 String
   size                   Int
   preview                String
   storageName            String                @map("storage_name")
   comment                String?
   createdAt              DateTime              @default(now()) @map("created_at")
   updatedAt              DateTime              @default(now()) @updatedAt @map("updated_at")
   client                 Client?               @relation(fields: [clientId], references: [id])
   clientDraft            ClientDraft?          @relation(fields: [clientDraftId], references: [id])
   portfolio              Portfolio?            @relation(fields: [portfolioId], references: [id])
   portfolioDraft         PortfolioDraft?       @relation(fields: [portfolioDraftId], references: [id])
   entity                 Entity?               @relation(fields: [entityId], references: [id])
   asset                  Asset?                @relation(fields: [assetId], references: [id])
   request                Request?              @relation(fields: [requestId], references: [id])
   requestDraft           RequestDraft?         @relation(fields: [requestDraftId], references: [id])
   transaction            Transaction?          @relation(fields: [transactionId], references: [id])
   transactionDraft       TransactionDraft?     @relation(fields: [transactionDraftId], references: [id])
   report                 Report?               @relation(fields: [reportId], references: [id])
   reportDraft            ReportDraft?          @relation(fields: [reportDraftId], references: [id])
   assetBond              AssetBond?            @relation(fields: [assetBondId], references: [id])
   assetBondId            String?               @db.Uuid
   assetEquity            AssetEquity?          @relation(fields: [assetEquityId], references: [id])
   assetEquityId          String?               @db.Uuid
   assetDeposit           AssetDeposit?         @relation(fields: [assetDepositId], references: [id])
   assetDepositId         String?               @db.Uuid
   assetCrypto            AssetCrypto?          @relation(fields: [assetCryptoId], references: [id])
   assetCryptoId          String?               @db.Uuid
   assetMetal             AssetMetal?           @relation(fields: [assetMetalId], references: [id])
   assetMetalId           String?               @db.Uuid
   assetLoan              AssetLoan?            @relation(fields: [assetLoanId], references: [id])
   assetLoanId            String?               @db.Uuid
   assetOption            AssetOption?          @relation(fields: [assetOptionId], references: [id])
   assetOptionId          String?               @db.Uuid
   assetRealEstate        AssetRealEstate?      @relation(fields: [assetRealEstateId], references: [id])
   assetRealEstateId      String?               @db.Uuid
   assetOtherInvestment   AssetOtherInvestment? @relation(fields: [assetOtherInvestmentId], references: [id])
   assetOtherInvestmentId String?               @db.Uuid
   assetPrivateEquity     AssetPrivateEquity?   @relation(fields: [assetPrivateEquityId], references: [id])
   assetPrivateEquityId   String?               @db.Uuid
   assetCash              AssetCash?            @relation(fields: [assetCashId], references: [id])
   assetCashId            String?               @db.Uuid

   @@index([clientId])
   @@index([clientDraftId])
   @@index([portfolioId])
   @@index([portfolioDraftId])
   @@index([entityId])
   @@index([assetId])
   @@index([requestId])
   @@index([requestDraftId])
   @@index([transactionId])
   @@index([transactionDraftId])
}

/// A system-wide dictionary of known financial institutions.
///
/// This model serves as a reference catalog of standardized bank names.
/// While not directly related through foreign keys, its `name` field is intended
/// to correspond to the `bankName` field in the `Bank` model.
///
/// Used for validation, dropdown selection, and suggestions when users create `Bank` records.
model BankList {
   id        String   @id @unique @default(uuid()) @db.Uuid
   name      String   @unique
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
   banks     Bank[]
}

// Represents a financial container of assets and related financial operations owned by a client.
// A portfolio groups together entities, banks, accounts, transactions, and more.
// Can also act as a "parent" via mainPortfolioId for grouping sub-portfolios.
model Portfolio {
   id                           String                        @id @unique @default(uuid()) @db.Uuid
   clientId                     String                        @map("client_id") @db.Uuid
   name                         String
   type                         String
   isActivated                  Boolean                       @default(true) @map("is_activated")
   resident                     String?
   taxResident                  String?                       @map("tax_resident")
   mainPortfolioId              String?                       @map("main_portfolio_id")
   createdAt                    DateTime                      @default(now()) @map("created_at")
   updatedAt                    DateTime                      @default(now()) @updatedAt @map("updated_at")
   totals                       Decimal                       @default(0) @db.Decimal(65, 2)
   client                       Client                        @relation(fields: [clientId], references: [id], onDelete: Cascade)
   entities                     Entity[]
   banks                        Bank[]
   accounts                     Account[]
   assets                       Asset[]
   requests                     Request[]
   requestDrafts                RequestDraft[]
   orders                       Order[]
   orderDrafts                  OrderDraft[]
   transactions                 Transaction[]
   transactionDrafts            TransactionDraft[]
   reports                      Report[]
   reportDrafts                 ReportDraft[]
   documents                    Document[]
   assetBondGroup               AssetBondGroup[]
   assetDeposit                 AssetDeposit[]
   assetEquityGroup             AssetEquityGroup[]
   assetCryptoGroup             AssetCryptoGroup[]
   assetMetalGroup              AssetMetalGroup[]
   assetLoan                    AssetLoan[]
   assetOption                  AssetOption[]
   assetRealEstate              AssetRealEstate[]
   assetOtherInvestment         AssetOtherInvestment[]
   assetPrivateEquity           AssetPrivateEquity[]
   assetCash                    AssetCash[]
   assetLoanVersions            AssetLoanVersion[]
   assetDepositVersions         AssetDepositVersion[]
   assetOptionVersions          AssetOptionVersion[]
   assetBondVersions            AssetBondVersion[]
   assetOtherInvestmentVersions AssetOtherInvestmentVersion[]
   assetPrivateEquityVersions   AssetPrivateEquityVersion[]
   assetRealEstateVersions      AssetRealEstateVersion[]
   assetEquityVersions          AssetEquityVersion[]

   @@index([clientId])
   @@index([mainPortfolioId])
   @@index([type])
   @@index([isActivated])
}

// Draft version of a portfolio used when onboarding or modifying portfolio structure.
// Mirrors Portfolio structure but is not yet activated.
model PortfolioDraft {
   id              String     @id @unique @default(uuid()) @db.Uuid
   clientId        String     @map("client_id") @db.Uuid
   name            String
   type            String
   resident        String?
   taxResident     String?    @map("tax_resident")
   mainPortfolioId String?    @map("main_portfolio_id")
   createdAt       DateTime   @default(now()) @map("created_at")
   updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at")
   client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
   entities        Entity[]
   banks           Bank[]
   accounts        Account[]
   assets          Asset[]
   documents       Document[]

   @@index([clientId])
   @@index([mainPortfolioId])
}

// A legal or operational entity (e.g., a company, trust, or individual entity) within a portfolio.
// Entities can own assets, hold bank accounts, and execute transactions.
model Entity {
   id                           String                        @id @unique @default(uuid()) @db.Uuid
   portfolioId                  String?                       @map("portfolio_id") @db.Uuid
   portfolioDraftId             String?                       @map("portfolio_draft_id") @db.Uuid
   name                         String
   country                      String
   authorizedSignatoryName      String                        @map("authorized_signatory_name")
   firstName                    String?                       @map("first_name")
   lastName                     String?                       @map("last_name")
   email                        String?
   createdAt                    DateTime                      @default(now()) @map("created_at")
   updatedAt                    DateTime                      @default(now()) @updatedAt @map("updated_at")
   portfolio                    Portfolio?                    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   portfolioDraft               PortfolioDraft?               @relation(fields: [portfolioDraftId], references: [id], onDelete: Cascade)
   banks                        Bank[]
   accounts                     Account[]
   assets                       Asset[]
   requests                     Request[]
   requestDrafts                RequestDraft[]
   transactions                 Transaction[]
   transactionDrafts            TransactionDraft[]
   documents                    Document[]
   assetBondGroup               AssetBondGroup[]
   assetDeposit                 AssetDeposit[]
   assetEquityGroup             AssetEquityGroup[]
   assetCryptoGroup             AssetCryptoGroup[]
   assetMetalGroup              AssetMetalGroup[]
   assetLoan                    AssetLoan[]
   assetOption                  AssetOption[]
   assetRealEstate              AssetRealEstate[]
   assetOtherInvestment         AssetOtherInvestment[]
   assetPrivateEquity           AssetPrivateEquity[]
   assetCash                    AssetCash[]
   assetLoanVersions            AssetLoanVersion[]
   assetDepositVersions         AssetDepositVersion[]
   assetOptionVersions          AssetOptionVersion[]
   assetBondVersions            AssetBondVersion[]
   assetOtherInvestmentVersions AssetOtherInvestmentVersion[]
   assetPrivateEquityVersions   AssetPrivateEquityVersion[]
   assetRealEstateVersions      AssetRealEstateVersion[]
   assetEquityVersions          AssetEquityVersion[]

   @@index([portfolioId])
   @@index([portfolioDraftId])
   @@index([name])
}

/// Represents a specific bank used by the client, entity, or portfolio.
/// Each `Bank` can be linked to multiple `Account` records and included in budget planning.
model Bank {
   id                           String                        @id @unique @default(uuid()) @db.Uuid
   clientId                     String                        @map("client_id") @db.Uuid
   portfolioId                  String?                       @map("portfolio_id") @db.Uuid
   portfolioDraftId             String?                       @map("portfolio_draft_id") @db.Uuid
   entityId                     String                        @map("entity_id") @db.Uuid
   bankListId                   String?                       @map("bank_list_id") @db.Uuid
   bankName                     String                        @map("bank_name") @db.VarChar(50)
   country                      String
   branchName                   String                        @map("branch_name")
   firstName                    String?                       @map("first_name")
   lastName                     String?                       @map("last_name")
   email                        String?
   createdAt                    DateTime                      @default(now()) @map("created_at")
   updatedAt                    DateTime                      @default(now()) @updatedAt @map("updated_at")
   client                       Client?                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
   portfolio                    Portfolio?                    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   portfolioDraft               PortfolioDraft?               @relation(fields: [portfolioDraftId], references: [id], onDelete: Cascade)
   entity                       Entity?                       @relation(fields: [entityId], references: [id], onDelete: Cascade)
   bankList                     BankList?                     @relation(fields: [bankListId], references: [id])
   accounts                     Account[]
   assets                       Asset[]
   requests                     Request[]
   requestDrafts                RequestDraft[]
   transactions                 Transaction[]
   transactionsDrafts           TransactionDraft[]
   budgetPlanBankAccounts       BudgetPlanBankAccount[]
   assetBondGroup               AssetBondGroup[]
   assetDeposit                 AssetDeposit[]
   assetEquityGroup             AssetEquityGroup[]
   assetCryptoGroup             AssetCryptoGroup[]
   assetMetalGroup              AssetMetalGroup[]
   assetLoan                    AssetLoan[]
   assetOption                  AssetOption[]
   assetRealEstate              AssetRealEstate[]
   assetOtherInvestment         AssetOtherInvestment[]
   assetPrivateEquity           AssetPrivateEquity[]
   assetCash                    AssetCash[]
   assetLoanVersions            AssetLoanVersion[]
   assetDepositVersions         AssetDepositVersion[]
   assetOptionVersions          AssetOptionVersion[]
   assetBondVersions            AssetBondVersion[]
   assetOtherInvestmentVersions AssetOtherInvestmentVersion[]
   assetPrivateEquityVersions   AssetPrivateEquityVersion[]
   assetRealEstateVersions      AssetRealEstateVersion[]
   assetEquityVersions          AssetEquityVersion[]

   @@index([portfolioId])
   @@index([portfolioDraftId])
   @@index([entityId])
   @@index([bankName])
   @@index([clientId])
}

// A bank account (checking, brokerage, etc.) used by a portfolio or entity.
// Tracks associated assets, fees, budget allocations, and is key in financial reporting.
model Account {
   id                           String                        @id @unique @default(uuid()) @db.Uuid
   portfolioId                  String?                       @map("portfolio_id") @db.Uuid
   portfolioDraftId             String?                       @map("portfolio_draft_id") @db.Uuid
   entityId                     String                        @map("entity_id") @db.Uuid
   bankId                       String                        @map("bank_id") @db.Uuid
   accountName                  String                        @map("account_name")
   managementFee                String                        @map("management_fee") @db.VarChar(50)
   holdFee                      String                        @map("hold_fee") @db.VarChar(50)
   sellFee                      String                        @map("sell_fee") @db.VarChar(50)
   buyFee                       String                        @map("buy_fee") @db.VarChar(50)
   description                  String?
   dataCreated                  DateTime?                     @map("data_created")
   iban                         String?                       @db.VarChar(50)
   accountNumber                String?                       @map("account_number") @db.VarChar(50)
   comment                      String?
   createdAt                    DateTime                      @default(now()) @map("created_at")
   updatedAt                    DateTime                      @default(now()) @updatedAt @map("updated_at")
   portfolio                    Portfolio?                    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   portfolioDraft               PortfolioDraft?               @relation(fields: [portfolioDraftId], references: [id], onDelete: Cascade)
   entity                       Entity?                       @relation(fields: [entityId], references: [id], onDelete: Cascade)
   bank                         Bank?                         @relation(fields: [bankId], references: [id], onDelete: Cascade)
   assets                       Asset[]
   requests                     Request[]
   requestDrafts                RequestDraft[]
   transactions                 Transaction[]
   transactionDrafts            TransactionDraft[]
   budgetPlanBankAccounts       BudgetPlanBankAccount[]
   budgetPlanAllocations        BudgetPlanAllocation[]
   assetBondGroup               AssetBondGroup[]
   assetDeposit                 AssetDeposit[]
   assetEquityGroup             AssetEquityGroup[]
   assetCryptoGroup             AssetCryptoGroup[]
   assetMetalGroup              AssetMetalGroup[]
   assetLoan                    AssetLoan[]
   assetOption                  AssetOption[]
   assetRealEstate              AssetRealEstate[]
   assetOtherInvestment         AssetOtherInvestment[]
   assetPrivateEquity           AssetPrivateEquity[]
   assetCash                    AssetCash[]
   assetLoanVersions            AssetLoanVersion[]
   assetDepositVersions         AssetDepositVersion[]
   assetOptionVersions          AssetOptionVersion[]
   assetBondVersions            AssetBondVersion[]
   assetOtherInvestmentVersions AssetOtherInvestmentVersion[]
   assetPrivateEquityVersions   AssetPrivateEquityVersion[]
   assetRealEstateVersions      AssetRealEstateVersion[]
   assetEquityVersions          AssetEquityVersion[]

   @@index([portfolioId])
   @@index([portfolioDraftId])
   @@index([entityId])
   @@index([bankId])
}

// A financial instrument such as stock, bond, or real estate.
// Belongs to a Client and is tracked across various dimensions such as bank, account, entity, or portfolio.
// Includes dynamic JSON payload to store type-specific attributes (e.g., ISIN, quantity).
/// The `payload` field may contain a `serviceProvider` property for certain asset types.
/// This value should correspond to `ServiceProvidersList.name` to ensure naming consistency across assets and transactions.
/// The `payload` field may contain an `isin` value, referencing a financial instrument.
/// This should match an entry in the `Isins.isin` registry to ensure consistency across reports and transactions.
model Asset {
   id               String          @id @unique @default(uuid()) @db.Uuid
   clientId         String          @map("client_id") @db.Uuid
   portfolioId      String?         @map("portfolio_id") @db.Uuid
   portfolioDraftId String?         @map("portfolio_draft_id") @db.Uuid
   entityId         String          @map("entity_id") @db.Uuid
   bankId           String          @map("bank_id") @db.Uuid
   accountId        String          @map("account_id") @db.Uuid
   assetName        String          @map("asset_name") @db.VarChar(50)
   payload          Json
   rate             Float?
   isArchived       Boolean         @default(false) @map("is_archived")
   isFutureDated    Boolean         @default(false) @map("is_future_dated")
   createdAt        DateTime        @default(now()) @map("created_at")
   updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")
   portfolio        Portfolio?      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   portfolioDraft   PortfolioDraft? @relation(fields: [portfolioDraftId], references: [id], onDelete: Cascade)
   entity           Entity?         @relation(fields: [entityId], references: [id], onDelete: Cascade)
   bank             Bank?           @relation(fields: [bankId], references: [id], onDelete: Cascade)
   account          Account?        @relation(fields: [accountId], references: [id], onDelete: Cascade)
   client           Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
   requests         Request[]
   requestDrafts    RequestDraft[]
   documents        Document[]
   transaction      Transaction[]

   @@index([portfolioId])
   @@index([portfolioDraftId])
   @@index([entityId])
   @@index([bankId])
   @@index([accountId])
   @@index([clientId])
   @@index([assetName])
   @@index([isArchived])
   @@index([isFutureDated])
}

// Represents a formal client instruction to perform an action (buy, sell, deposit, etc.).
// May result in an Order and eventually in one or more Transactions.
// Linked to supporting entities like Account, Bank, Asset, and Portfolio.
model Request {
   id            Int          @id @default(autoincrement())
   clientId      String       @map("client_id") @db.Uuid
   portfolioId   String       @map("portfolio_id") @db.Uuid
   entityId      String       @map("entity_id") @db.Uuid
   bankId        String       @map("bank_id") @db.Uuid
   accountId     String       @map("account_id") @db.Uuid
   assetId       String?      @map("asset_id") @db.Uuid
   orderId       Int?         @map("order_id")
   type          RequestType
   status        String       @default("Not started") @db.VarChar(50)
   amount        String?      @db.VarChar(50)
   comment       String?      @db.Text
   createdAt     DateTime     @default(now()) @map("created_at")
   updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")
   client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
   portfolio     Portfolio?   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   entity        Entity?      @relation(fields: [entityId], references: [id], onDelete: Cascade)
   bank          Bank?        @relation(fields: [bankId], references: [id], onDelete: Cascade)
   account       Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
   asset         Asset?       @relation(fields: [assetId], references: [id])
   orders        Order[]
   orderDrafts   OrderDraft[]
   documents     Document[]
   assetBond     AssetBond?   @relation(fields: [assetBondId], references: [id])
   assetBondId   String?      @db.Uuid
   assetEquity   AssetEquity? @relation(fields: [assetEquityId], references: [id])
   assetEquityId String?      @db.Uuid

   @@index([clientId])
   @@index([portfolioId])
   @@index([entityId])
   @@index([bankId])
   @@index([accountId])
   @@index([assetId])
   @@index([type])
   @@index([status])
}

// A pre-submission version of a Request.
// Used to allow clients or back-office users to prepare requests before finalizing.
model RequestDraft {
   id            Int          @id @default(autoincrement())
   clientId      String?      @map("client_id") @db.Uuid
   portfolioId   String?      @map("portfolio_id") @db.Uuid
   entityId      String?      @map("entity_id") @db.Uuid
   bankId        String?      @map("bank_id") @db.Uuid
   accountId     String?      @map("account_id") @db.Uuid
   assetId       String?      @map("asset_id") @db.Uuid
   type          RequestType
   amount        String?      @db.VarChar(50)
   comment       String?      @db.Text
   createdAt     DateTime     @default(now()) @map("created_at")
   updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")
   client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
   portfolio     Portfolio?   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   entity        Entity?      @relation(fields: [entityId], references: [id], onDelete: Cascade)
   bank          Bank?        @relation(fields: [bankId], references: [id], onDelete: Cascade)
   account       Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
   asset         Asset?       @relation(fields: [assetId], references: [id])
   documents     Document[]
   assetBond     AssetBond?   @relation(fields: [assetBondId], references: [id])
   assetBondId   String?      @db.Uuid
   assetEquity   AssetEquity? @relation(fields: [assetEquityId], references: [id])
   assetEquityId String?      @db.Uuid

   @@index([clientId])
   @@index([portfolioId])
   @@index([entityId])
   @@index([bankId])
   @@index([accountId])
   @@index([assetId])
   @@index([type])
}

// Represents a confirmed instruction to a broker or system to execute a trade.
// Tied to a specific Request and Portfolio.
// Can include multiple OrderDetails and track execution lifecycle.
model Order {
   id                Int                @id @default(autoincrement())
   portfolioId       String             @map("portfolio_id") @db.Uuid
   requestId         Int                @map("request_id")
   type              OrderType
   status            String             @default("In progress")
   createdAt         DateTime           @default(now()) @map("created_at")
   updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")
   portfolio         Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   request           Request            @relation(fields: [requestId], references: [id], onDelete: Cascade)
   details           OrderDetails[]
   transactions      Transaction[]
   transactionDrafts TransactionDraft[]

   @@index([type])
   @@index([status])
   @@index([portfolioId])
   @@index([requestId])
}

/// Itemized breakdown of an Order, representing individual securities or units within that order.
/// Includes ISIN, currency, units, and executed prices
/// The `isin` field represents the financial instrument code for this order item.
/// It should match an existing `Isins.isin` to validate and classify the asset being traded.
model OrderDetails {
   id            String   @id @default(uuid()) @db.Uuid
   orderId       Int      @map("order_id")
   security      String   @db.VarChar(50)
   isin          String   @db.VarChar(50)
   units         String   @db.VarChar(50)
   priceType     String   @map("price_type") @db.VarChar(50)
   price         String   @db.VarChar(50)
   currency      String   @db.VarChar(10)
   unitExecuted  String?  @map("unit_executed") @db.VarChar(50)
   priceExecuted String?  @map("price_executed") @db.VarChar(50)
   yield         String?  @db.VarChar(50)
   createdAt     DateTime @default(now()) @map("created_at")
   updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
   order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

   @@index([orderId])
}

// Editable version of an Order before finalization.
// Can be saved incrementally and adjusted without impacting actual trading state.
model OrderDraft {
   id          Int                 @id @default(autoincrement())
   portfolioId String?             @map("portfolio_id") @db.Uuid
   requestId   Int?                @map("request_id")
   type        OrderType
   createdAt   DateTime            @default(now()) @map("created_at")
   updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at")
   portfolio   Portfolio?          @relation(fields: [portfolioId], references: [id])
   request     Request?            @relation(fields: [requestId], references: [id])
   details     OrderDraftDetails[]

   @@index([type])
   @@index([portfolioId])
   @@index([requestId])
}

/// Line items in an OrderDraft, holding editable trade details similar to OrderDetails.
/// The `isin` field stores the provisional instrument code during draft order creation.
/// Its value is expected to align with `Isins.isin` for consistency in future validation.
model OrderDraftDetails {
   id            String     @id @default(uuid()) @db.Uuid
   orderDraftId  Int        @map("order_draft_id")
   security      String?    @db.VarChar(50)
   isin          String?    @db.VarChar(50)
   units         String?    @db.VarChar(50)
   priceType     String?    @map("price_type") @db.VarChar(50)
   price         String?    @db.VarChar(50)
   currency      String?    @db.VarChar(10)
   yield         String?    @db.VarChar(50)
   unitExecuted  String?    @default("0") @map("unit_executed") @db.VarChar(50)
   priceExecuted String?    @map("price_executed") @db.VarChar(50)
   createdAt     DateTime   @default(now()) @map("created_at")
   updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at")
   orderDraft    OrderDraft @relation(fields: [orderDraftId], references: [id], onDelete: Cascade)

   @@index([orderDraftId])
}

model TransactionTypeCategory {
   id                     String                   @id @default(uuid()) @db.Uuid
   name                   String                   @unique
   isDeleted              Boolean                  @default(false)
   createdAt              DateTime                 @default(now())
   updatedAt              DateTime                 @default(now()) @updatedAt
   TransactionTypeDraft   TransactionTypeDraft[]
   TransactionTypeVersion TransactionTypeVersion[]
}

model TransactionTypeAuditTrail {
   id                              String           @id @unique @default(uuid()) @db.Uuid
   userName                        String?
   userRole                        String?
   settingsType                    String?
   transactionTypeNameFrom         String?
   transactionTypeNameTo           String?
   transactionTypeCategoryFrom     String?
   transactionTypeCategoryTo       String?
   transactionTypeCashflowFrom     String?
   transactionTypeCashflowTo       String?
   transactionTypePlFrom           String?
   transactionTypePlTo             String?
   transactionTypeAnnualFrom       String[]
   transactionTypeAnnualTo         String[]
   transactionTypeCommentFrom      String?
   transactionTypeCommentTo        String?
   transactionTypeRelatedTypeFrom  String?
   transactionTypeRelatedTypeTo    String?
   transactionTypeRelatedAssetFrom String?
   transactionTypeRelatedAssetTo   String?
   createdAt                       DateTime         @default(now()) @map("created_at")
   updatedAt                       DateTime         @default(now()) @updatedAt @map("updated_at")
   transactionTypeId               String?          @map("transaction_type_id") @db.Uuid
   transactionType                 TransactionType? @relation(fields: [transactionTypeId], references: [id], onDelete: SetNull)

   @@index([transactionTypeId])
}

// Defines categories of transactions (e.g., income, expense, investment).
// Used for filtering, reporting, and automated logic around cash flow and P&L analysis.
// Linked to both actual and draft transactions.

model TransactionTypeVersion {
   id               String                   @id @default(uuid()) @db.Uuid
   typeId           String                   @map("type_id") @db.Uuid
   type             TransactionType          @relation(fields: [typeId], references: [id], onDelete: Cascade)
   version          Int                      @default(1) @map("version")
   name             String
   categoryId       String?                  @map("category_id") @db.Uuid
   categoryType     TransactionTypeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
   cashFlow         String                   @map("cash_flow")
   pl               String?
   annualAssets     String[]
   comment          String?
   isCurrent        Boolean                  @default(true) @map("is_current")
   createdAt        DateTime                 @default(now()) @map("created_at")
   Transaction      Transaction[]
   TransactionDraft TransactionDraft[]

   @@unique([typeId, version])
   @@index([typeId, isCurrent])
   @@index([categoryId])
}

model TransactionType {
   id                        String                      @id @default(uuid()) @db.Uuid
   relatedTypeId             String?                     @map("related_type_id") @db.Uuid
   relatedType               TransactionType?            @relation("TransactionTypeRelation", fields: [relatedTypeId], references: [id], onDelete: SetNull)
   relatedChildren           TransactionType[]           @relation("TransactionTypeRelation")
   asset                     String?
   isActivated               Boolean                     @default(true)
   isDeleted                 Boolean                     @default(false)
   counter                   Int                         @default(0)
   createdAt                 DateTime                    @default(now()) @map("created_at")
   updatedAt                 DateTime                    @default(now()) @updatedAt @map("updated_at")
   versions                  TransactionTypeVersion[]
   transactions              Transaction[]
   transactionDrafts         TransactionDraft[]
   TransactionTypeAuditTrail TransactionTypeAuditTrail[]
   transactionTypeCategoryId String?                     @db.Uuid

   @@index([isActivated])
   @@index([isDeleted])
   @@index([relatedTypeId])
}

model TransactionTypeDraft {
   id           String                   @id @unique @default(uuid()) @db.Uuid
   name         String?
   category     String?
   cashFlow     String?                  @map("cash_flow")
   pl           String?
   createdAt    DateTime                 @default(now()) @map("created_at")
   updatedAt    DateTime                 @default(now()) @updatedAt @map("updated_at")
   counter      Int                      @default(0)
   comment      String?
   asset        String?
   categoryId   String?                  @map("category_id") @db.Uuid
   categoryType TransactionTypeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
   annualAssets String[]

   @@index([name])
   @@index([categoryId])
}

/// Represents a confirmed financial event (e.g. asset purchase, cash movement).
/// Associated with transaction type, account, and client.
/// Used for audit, reports, and financial summaries.
/// The `serviceProvider` field is a free-text reference that should correspond to `ServiceProvidersList.name`,
/// allowing consistent naming and optional dictionary-based filtering in analytics or reporting.
/// The `isin` field identifies the traded instrument in this financial transaction.
/// It should match an entry in `Isins.isin` to support classification and analytics.
model Transaction {
   id                       Int                     @id @default(autoincrement())
   transactionTypeId        String                  @map("transaction_type_id") @db.Uuid
   clientId                 String                  @map("client_id") @db.Uuid
   portfolioId              String                  @map("portfolio_id") @db.Uuid
   entityId                 String?                 @map("entity_id") @db.Uuid
   bankId                   String                  @map("bank_id") @db.Uuid
   accountId                String?                 @map("account_id") @db.Uuid
   assetId                  String?                 @map("asset_id") @db.Uuid
   orderId                  Int?                    @map("order_id")
   expenseCategoryId        String?                 @map("expense_category_id") @db.Uuid
   isin                     String?                 @db.VarChar(50)
   security                 String?                 @db.VarChar(50)
   serviceProvider          String?                 @map("service_provider")
   currency                 String                  @db.VarChar(10)
   rate                     Float?
   amount                   Decimal                 @db.Decimal(65, 2)
   transactionDate          DateTime                @default(now()) @map("transaction_date")
   comment                  String?                 @db.Text
   customFields             Json?                   @map("custom_fields")
   isFutureDated            Boolean                 @default(false) @map("is_future_dated")
   createdAt                DateTime                @default(now()) @map("created_at")
   updatedAt                DateTime                @default(now()) @updatedAt @map("updated_at")
   transactionType          TransactionType?        @relation(fields: [transactionTypeId], references: [id], onDelete: Cascade)
   client                   Client?                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
   portfolio                Portfolio?              @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   entity                   Entity?                 @relation(fields: [entityId], references: [id], onDelete: Cascade)
   bank                     Bank?                   @relation(fields: [bankId], references: [id], onDelete: Cascade)
   account                  Account?                @relation(fields: [accountId], references: [id], onDelete: Cascade)
   asset                    Asset?                  @relation(fields: [assetId], references: [id], onDelete: Cascade)
   order                    Order?                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
   expenseCategory          ExpenseCategory?        @relation(fields: [expenseCategoryId], references: [id])
   documents                Document[]
   transactionTypeVersionId String?                 @map("transaction_type_version_id") @db.Uuid
   typeVersion              TransactionTypeVersion? @relation(fields: [transactionTypeVersionId], references: [id], onDelete: Cascade)

   assetBondGroups   AssetBondGroup[]
   assetEquityGroups AssetEquityGroup[]
   assetCryptoGroups AssetCryptoGroup[]
   assetCashes       AssetCash[]
   equity            Equity?            @relation(fields: [equityId], references: [id])
   equityId          Int?
   assetMetalGroup   AssetMetalGroup?   @relation(fields: [assetMetalGroupId], references: [id])
   assetMetalGroupId String?            @db.Uuid

   assetBond                     AssetBond?                   @relation(fields: [assetBondId], references: [id])
   assetBondId                   String?                      @db.Uuid
   assetEquity                   AssetEquity?                 @relation(fields: [assetEquityId], references: [id])
   assetEquityId                 String?                      @db.Uuid
   assetDeposit                  AssetDeposit?                @relation(fields: [assetDepositId], references: [id])
   assetDepositId                String?                      @db.Uuid
   assetCrypto                   AssetCrypto?                 @relation(fields: [assetCryptoId], references: [id])
   assetCryptoId                 String?                      @db.Uuid
   assetMetal                    AssetMetal?                  @relation(fields: [assetMetalId], references: [id])
   assetMetalId                  String?                      @db.Uuid
   assetLoan                     AssetLoan?                   @relation(fields: [assetLoanId], references: [id])
   assetLoanId                   String?                      @db.Uuid
   assetOption                   AssetOption?                 @relation(fields: [assetOptionId], references: [id])
   assetOptionId                 String?                      @db.Uuid
   assetRealEstate               AssetRealEstate?             @relation(fields: [assetRealEstateId], references: [id])
   assetRealEstateId             String?                      @db.Uuid
   assetOtherInvestmentId        String?                      @db.Uuid
   assetPrivateEquity            AssetPrivateEquity?          @relation(fields: [assetPrivateEquityId], references: [id])
   assetPrivateEquityId          String?                      @db.Uuid
   assetOtherInvestmentVersion   AssetOtherInvestmentVersion? @relation(fields: [assetOtherInvestmentVersionId], references: [id])
   assetOtherInvestmentVersionId String?                      @db.Uuid

   @@index([transactionTypeVersionId])
   @@index([entityId])
   @@index([clientId])
   @@index([portfolioId])
   @@index([bankId])
   @@index([accountId])
   @@index([orderId])
   @@index([currency])
}

/// Temporary draft version of a Transaction.
/// Allows safe editing or simulation of transactions before they’re finalized.
/// The `serviceProvider` field is a free-text reference that should correspond to `ServiceProvidersList.name`,
/// allowing consistent naming and optional dictionary-based filtering in analytics or reporting.
/// The `isin` field temporarily holds the instrument code during transaction planning.
/// Once finalized, this should correspond with `Isins.isin` for traceability and reporting.

model TransactionDraft {
   id                Int              @id @default(autoincrement())
   transactionTypeId String?          @map("transaction_type_id") @db.Uuid
   clientId          String?          @map("client_id") @db.Uuid
   portfolioId       String?          @map("portfolio_id") @db.Uuid
   entityId          String?          @map("entity_id") @db.Uuid
   bankId            String?          @map("bank_id") @db.Uuid
   accountId         String?          @map("account_id") @db.Uuid
   orderId           Int?             @map("order_id")
   isin              String?          @db.VarChar(50)
   security          String?          @db.VarChar(50)
   serviceProvider   String?          @map("service_provider")
   currency          String?          @db.VarChar(3)
   amount            Decimal?         @db.Decimal(65, 2)
   transactionDate   DateTime?        @map("transaction_date")
   comment           String?          @db.Text
   customFields      Json?            @map("custom_fields")
   createdAt         DateTime         @default(now()) @map("created_at")
   updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")
   transactionType   TransactionType? @relation(fields: [transactionTypeId], references: [id], onDelete: Cascade)
   client            Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
   portfolio         Portfolio?       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   entity            Entity?          @relation(fields: [entityId], references: [id], onDelete: Cascade)
   bank              Bank?            @relation(fields: [bankId], references: [id], onDelete: Cascade)
   account           Account?         @relation(fields: [accountId], references: [id], onDelete: Cascade)
   order             Order?           @relation(fields: [orderId], references: [id], onDelete: Cascade)
   documents         Document[]

   transactionTypeVersionId String                 @map("transaction_type_version_id") @db.Uuid
   typeVersion              TransactionTypeVersion @relation(fields: [transactionTypeVersionId], references: [id], onDelete: Cascade)

   @@index([entityId])
   @@index([clientId])
   @@index([portfolioId])
   @@index([bankId])
   @@index([accountId])
   @@index([orderId])
   @@index([currency])
}

// A long-term financial strategy for managing client expenses and goals.
// Defines allocations across bank accounts, expense categories, and assets.
model BudgetPlan {
   id                     String                  @id @unique @default(uuid()) @db.Uuid
   clientId               String                  @unique @map("client_id") @db.Uuid
   name                   String
   isActivated            Boolean?                @default(true) @map("is_activated")
   createdAt              DateTime                @default(now()) @map("created_at")
   updatedAt              DateTime                @default(now()) @updatedAt @map("updated_at")
   client                 Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
   budgetPlanBankAccounts BudgetPlanBankAccount[]
   allocations            BudgetPlanAllocation[]
   expenseCategories      ExpenseCategory[]
}

// Draft version of a BudgetPlan.
// Used for planning or proposals before the budget is committed.
model BudgetPlanDraft {
   id                     String                  @id @unique @default(uuid()) @db.Uuid
   clientId               String                  @unique @map("client_id") @db.Uuid
   name                   String?
   createdAt              DateTime                @default(now()) @map("created_at")
   updatedAt              DateTime                @default(now()) @updatedAt @map("updated_at")
   client                 Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
   budgetPlanBankAccounts BudgetPlanBankAccount[]
   allocations            BudgetPlanAllocation[]
}

// Linking table associating specific bank accounts with a BudgetPlan or BudgetPlanDraft.
// Allows multi-bank budgeting.
model BudgetPlanBankAccount {
   id                String           @unique @default(uuid()) @db.Uuid
   bankId            String           @map("bank_id") @db.Uuid
   accountId         String           @map("account_id") @db.Uuid
   budgetPlanId      String?          @map("budget_plan_id") @db.Uuid
   budgetPlanDraftId String?          @map("budget_plan_draft_id") @db.Uuid
   bank              Bank             @relation(fields: [bankId], references: [id])
   account           Account          @relation(fields: [accountId], references: [id])
   budgetPlan        BudgetPlan?      @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
   budgetPlanDraft   BudgetPlanDraft? @relation(fields: [budgetPlanDraftId], references: [id], onDelete: Cascade)
}

// Defines how much budget is allocated in a specific currency for a given account.
// Connected to either BudgetPlan or BudgetPlanDraft.
model BudgetPlanAllocation {
   id                String           @id @unique @default(uuid()) @db.Uuid
   budgetPlanId      String?          @map("budget_plan_id") @db.Uuid
   budgetPlanDraftId String?          @map("budget_plan_draft_id") @db.Uuid
   accountId         String           @map("account_id") @db.Uuid
   currency          CurrencyDataList
   amount            Float
   budget            Float
   createdAt         DateTime         @default(now()) @map("created_at")
   updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")
   budgetPlan        BudgetPlan?      @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
   budgetPlanDraft   BudgetPlanDraft? @relation(fields: [budgetPlanDraftId], references: [id], onDelete: Cascade)
   account           Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

/// Represents budget categories like Rent, Utilities, Investments, etc.
/// Belongs to a BudgetPlan and groups Transactions by purpose or theme.
/// The `name` field is typically selected from the `ExpenseCategoryList` model, 
/// which acts as a static reference dictionary of predefined category names.
/// This allows consistency and reusability across multiple budgets, 
/// although there is no enforced foreign key relation.
model ExpenseCategory {
   id           String        @id @unique @default(uuid()) @db.Uuid
   budgetPlanId String        @map("budget_plan_id") @db.Uuid
   name         String
   budget       Float
   createdAt    DateTime      @default(now()) @map("created_at")
   updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
   budgetPlan   BudgetPlan    @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
   transactions Transaction[]

   @@index([name])
   @@index([budget])
}

/// Defines static, reusable category names used for budgeting and transaction grouping.
/// Used as a reference when creating entries in the `ExpenseCategory` model to 
/// ensure consistent naming and reporting.
model ExpenseCategoryList {
   id        String   @id @unique @default(uuid()) @db.Uuid
   clientId  String?  @map("client_id") @db.Uuid
   name      String   @unique
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
   client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

/// A structured, formal output such as investment summary or asset evaluation.
/// Can be generated for clients or portfolios and includes linked Documents.
/// The `isins` array holds a list of referenced instrument codes included in the report.
/// These codes should be present in `Isins.isin` to enable proper categorization and filtering.
model Report {
   id          Int        @id @default(autoincrement())
   clientId    String?    @map("client_id") @db.Uuid
   portfolioId String?    @map("portfolio_id") @db.Uuid
   type        String     @db.VarChar(50)
   category    String     @db.VarChar(50)
   name        String     @db.VarChar(100)
   isins       String[]   @default([]) @db.VarChar(50)
   payload     Json?
   createdBy   String?    @map("created_by") @db.VarChar(150)
   createdAt   DateTime   @default(now()) @map("created_at")
   updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at")
   client      Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
   portfolio   Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   documents   Document[]

   @@index([type])
   @@index([category])
}

/// Draft version of a report under preparation.
/// May be saved as a work-in-progress before final publishing.
/// The `isins` array lists the provisional instruments to be included in the draft report.
/// These should refer to known `Isins.isin` values to ensure consistency on finalization.
model ReportDraft {
   id          Int        @id @default(autoincrement())
   clientId    String?    @map("client_id") @db.Uuid
   portfolioId String?    @map("portfolio_id") @db.Uuid
   type        String     @db.VarChar(50)
   category    String     @db.VarChar(50)
   name        String     @db.VarChar(100)
   isins       String[]   @default([]) @db.VarChar(50)
   payload     Json?
   createdBy   String?    @map("created_by") @db.VarChar(150)
   createdAt   DateTime   @default(now()) @map("created_at")
   updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at")
   client      Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
   portfolio   Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
   documents   Document[]
}

/// - Lists service providers with unique names.
/// - Used as a reference dictionary for the `serviceProvider` field in the `Transaction` model,
///   and for the `serviceProvider` key inside the `payload` of some `Asset` entries.
/// - This allows consistent usage of provider names across different financial data sources.
model ServiceProvidersList {
   id        String   @id @unique @default(uuid()) @db.Uuid
   name      String   @unique
   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
}

// - Stores CBonds API datasets in JSON format for financial analytics.
model CBonds {
   id                    String   @id @unique @default(uuid()) @db.Uuid
   tradingsNew           Json     @map("tradings_new")
   emissions             Json
   tradingsStocksFullNew Json     @map("tradings_stocks_full_new")
