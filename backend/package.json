{
	"name": "backend",
	"version": "1.0.0",
	"description": "",
	"author": "",
	"license": "UNLICENSED",
	"private": true,
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "pm2 start dist/src/main.js --name application -i max",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=0",
		"db:seed-main:dev": "ts-node prisma/main-db/seed.ts",
		"db:seed-third-party:dev": "ts-node prisma/third-party-db/seed.ts",
		"db:reset-main:dev": "yarn prisma migrate reset --schema prisma/main-db/schema.prisma --preview-feature",
		"db:reset-third-party:dev": "yarn prisma migrate reset --schema prisma/third-party-db/schema.prisma --preview-feature",
		"db:migrate-main:dev": "yarn prisma migrate dev --schema prisma/main-db/schema.prisma --preview-feature",
		"db:migrate-third-party:dev": "yarn prisma migrate dev --schema prisma/third-party-db/schema.prisma --preview-feature",
		"db:generate:dev": "yarn prisma generate --schema prisma/main-db/schema.prisma & yarn prisma generate --schema prisma/third-party-db/schema.prisma",
		"db:deploy:dev": "yarn prisma migrate deploy --preview-feature",
		"test": "jest --runInBand",
		"test:watch": "jest --watch",
		"test:cov": "jest --collect-coverage"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.645.0",
		"@aws-sdk/s3-request-presigner": "3.645.0",
		"@keyv/redis": "^4.4.0",
		"@nestjs/cache-manager": "^3.0.1",
		"@nestjs/cli": "10.3.0",
		"@nestjs/common": "10.3.0",
		"@nestjs/config": "3.1.1",
		"@nestjs/core": "10.3.0",
		"@nestjs/event-emitter": "^3.0.1",
		"@nestjs/platform-express": "10.3.0",
		"@nestjs/platform-socket.io": "^11.1.3",
		"@nestjs/schedule": "4.0.0",
		"@nestjs/schematics": "10.1.0",
		"@nestjs/swagger": "7.2.0",
		"@nestjs/websockets": "^11.1.3",
		"@prisma/client": "5.8.1",
		"@socket.io/redis-adapter": "^8.3.0",
		"@types/socket.io": "^3.0.2",
		"@willsoto/nestjs-prometheus": "^6.0.2",
		"axios": "1.6.5",
		"bcrypt": "^5.1.1",
		"cache-manager": "^7.0.0",
		"class-transformer": "0.5.1",
		"class-validator": "0.14.1",
		"cookie-parser": "1.4.6",
		"date-fns": "^4.1.0",
		"dotenv": "16.3.2",
		"generate-password": "^1.7.1",
		"jsonwebtoken": "9.0.2",
		"keyv": "^5.3.4",
		"mailgun.js": "^10.2.4",
		"nestjs-prisma": "0.22.0",
		"otplib": "^12.0.1",
		"prisma": "5.8.1",
		"prom-client": "^15.1.3",
		"qrcode": "^1.5.4",
		"redis": "^5.8.2",
		"reflect-metadata": "0.1.13",
		"rxjs": "7.8.1",
		"sharp": "0.32.6",
		"swagger-ui-express": "5.0.0",
		"uuid": "9.0.1",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@nestjs/testing": "10.3.0",
		"@types/bcrypt": "5.0.2",
		"@types/cache-manager": "^5.0.0",
		"@types/cookie-parser": "1.4.6",
		"@types/express": "4.17.21",
		"@types/jest": "29.5.11",
		"@types/jsonwebtoken": "9.0.5",
		"@types/multer": "1.4.11",
		"@types/node": "^22.10.1",
		"@types/qrcode": "^1",
		"@types/redis": "^4.0.11",
		"@types/supertest": "2.0.16",
		"@types/uuid": "9.0.7",
		"@typescript-eslint/eslint-plugin": "6.19.0",
		"@typescript-eslint/parser": "6.19.0",
		"envalid": "8.0.0",
		"eslint": "8.56.0",
		"jest": "29.7.0",
		"lint-staged": "15.2.0",
		"node-mocks-http": "1.14.1",
		"source-map-support": "0.5.21",
		"supertest": "6.3.4",
		"ts-jest": "29.1.1",
		"ts-loader": "9.5.1",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "^5.7.2"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
